algoritmo "Dirigir"

Var
   idade: real

Inicio

   // Entrada de dados
   Escreval("Digite a sua idade:")
   Leia(idade)
   limpatela

   //Variável idade
   Se Idade >= 18 entao
      Escreva("Como é maior de idade, vocę pode dirigir.")
   senao
      Escreva("Por ser menor de idade, năo pode dirigir.")
   FimSe

Fimalgoritmo

