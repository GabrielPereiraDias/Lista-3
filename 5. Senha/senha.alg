algoritmo "senha do usuário"

var
senha, semha: literal

inicio
// Seção de Comandos 
   senha<- ("acd23")
   escreval ("Digite a senha do usuário: ")
   leia (semha)
   limpatela
   se senha = semha entao
   escreva ("Senha correta!")
   senao
   escreva ("Senha incorreta")
   fimse
fimalgoritmo
